# Environment variables for Shadow Deployment Framework

# Routing & Experiment
EXPERIMENT_SALT=your_random_salt_here

# Security
ADMIN_API_KEY=your_admin_api_key_here

# Infrastructure
REDIS_URL=redis://localhost:6379/0
SQLITE_DB_PATH=sqlite:///./evaluations.db

# LLM Endpoints
PRIMARY_LLM_URL=http://localhost:11434/api/generate
PRIMARY_MODEL_NAME=phi3:latest

SHADOW_LLM_URL=http://localhost:11434/api/generate
SHADOW_MODEL_NAME=llama3.2:3b

# Feature flags & configs
SHADOW_ENABLED_GLOBAL=true
CHALLENGER_TRAFFIC_WEIGHT=0.5
